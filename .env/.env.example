# Seul fichier versionné. Copier vers les fichiers locaux (non commités) :
#
#   .env.local   — API locale (pnpm run start)
#   .env.prod    — API production (pnpm run start:prod)
#
# L'app mobile ne parle qu'à l'API (pas de BDD ici).
# pnpm run start | start:local | start:prod

# Téléphone / tablette sur le Wi-Fi — IP du PC (ipconfig)
EXPO_PUBLIC_API_URL=http://192.168.1.178:8080/api/v1

# PC / simulateur iOS
# EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1

# Émulateur Android
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api/v1

# Production (.env.prod)
# EXPO_PUBLIC_API_URL=https://api.just-enjoy.app/api/v1
